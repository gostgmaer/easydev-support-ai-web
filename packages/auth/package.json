{
  "name": "@easydev/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@easydev/api-client": "workspace:*",
    "@easydev/design-system": "workspace:*",
    "@easydev/stores": "workspace:*",
    "@easydev/types": "workspace:*",
    "@easydev/utils": "workspace:*",
    "@hookform/resolvers": "^3.9.1",
    "react-hook-form": "^7.54.0",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.1",
    "next": "15.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
