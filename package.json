{
  "name": "easydev-support-ai-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:packages": "pnpm --filter \"./packages/**\" --filter !./packages/charts --filter !./packages/forms --filter !./packages/icons --filter !./packages/layouts run build",
    "typecheck:packages": "pnpm --filter \"./packages/**\" --filter !./packages/charts --filter !./packages/forms --filter !./packages/icons --filter !./packages/layouts run typecheck",
    "test:packages": "pnpm --filter \"./packages/**\" --filter !./packages/charts --filter !./packages/forms --filter !./packages/icons --filter !./packages/layouts run test",
    "dev:admin-portal": "pnpm --filter @easydev/admin-portal dev",
    "dev:agent-workspace": "pnpm --filter agent-workspace dev",
    "dev:customer-widget": "pnpm --filter @easydev/customer-widget dev",
    "dev:help-center": "pnpm --filter @easydev/help-center dev",
    "frontend:up": "bash scripts/frontend-up.sh",
    "frontend:down": "bash scripts/frontend-down.sh"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
